generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model Caracteristica {
  id_caracteristica         Int                         @id(map: "Caracteristica_pk") @default(autoincrement())
  nombre_caracteristica     String?                     @db.VarChar(128)
  PublicacionCaracteristica PublicacionCaracteristica[]

  @@schema("public")
}

model CategoriaNotificacion {
  id_categoria     Int            @id(map: "CategoriaNotificacion_pk") @default(autoincrement())
  nombre_categoria String?        @db.VarChar(128)
  Notificacion     Notificacion[]

  @@schema("public")
}

model Ciudad {
  id_ciudad         Int                 @id(map: "Ciudad_pk") @default(autoincrement()) @db.SmallInt
  nombre_ciudad     String?             @db.VarChar(128)
  descripcion_corta String?             @map("descripcion-corta")
  url_banner        String?
  CiudadImagen      CiudadImagen[]
  HistorialBusqueda HistorialBusqueda[]
  Ubicacion         Ubicacion[]
  Zona              Zona[]

  @@schema("public")
}

model CiudadImagen {
  id_ciudad_imagen  Int     @id(map: "CiudadImagen_pk") @default(autoincrement()) @db.SmallInt
  id_ciudad         Int?    @db.SmallInt
  orden             Int?    @db.SmallInt
  url_imagen_ciudad String?
  Ciudad            Ciudad? @relation(fields: [id_ciudad], references: [id_ciudad], onDelete: NoAction, onUpdate: NoAction, map: "fk_id_ciudad(CU)-id_ciudad(Ciudad)")

  @@schema("public")
}

model DetallePago {
  id_detalle      Int              @id(map: "DetallePago_pk") @default(autoincrement()) @db.SmallInt
  id_usuario      String?          @db.VarChar(128)
  id_plan         Int?             @db.SmallInt
  fecha_detalle   DateTime?        @db.Date
  estado          Int?             @db.SmallInt
  metodo_pago     String?          @db.VarChar(50)
  id_usuario      String?          @db.Uuid
  PlanPublicacion PlanPublicacion? @relation(fields: [id_plan], references: [id_plan], onDelete: NoAction, onUpdate: NoAction, map: "fk_detallepago_planpublicacion")
  Usuario         Usuario?         @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_detallepago_usuario")

  @@schema("public")
}

model EstadoConstruccion {
  id_estado_construccion     Int           @id(map: "EstadoConstruccion_pk") @default(autoincrement()) @db.SmallInt
  nombre_estado_construccion String?       @db.VarChar(128)
  Publicacion                Publicacion[]

  @@schema("public")
}

model EstadoPublicacion {
  id_estado     Int           @id(map: "EstadoPublicacion_pk") @default(autoincrement()) @db.SmallInt
  nombre_estado String?       @db.VarChar(128)
  Publicacion   Publicacion[]

  @@schema("public")
}

model Etiquetas {
  id_etiqueta     Int           @id(map: "Etiquetas_pk") @default(autoincrement()) @db.SmallInt
  nombre_etiqueta String?       @db.VarChar(128)
  color           String?       @db.VarChar(128)
  Publicacion     Publicacion[]

  @@schema("public")
}

model Favorito {
  id_publicacion Int
  id_usuario     String      @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  Publicacion    Publicacion @relation(fields: [id_publicacion], references: [id_publicacion], onDelete: NoAction, onUpdate: NoAction, map: "fk_favorito_publicacion")
  Usuario        Usuario     @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_favorito_usuario")

  @@id([id_usuario, id_publicacion], map: "Favorito_pk")
  @@schema("public")
}

model HistorialBusqueda {
  id_ciudad         Int           @db.SmallInt
  id_tipo_operacion Int           @db.SmallInt
  fecha_busqueda    DateTime      @db.Timestamptz(6)
  id_usuario        String        @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  Ciudad            Ciudad        @relation(fields: [id_ciudad], references: [id_ciudad], onDelete: NoAction, onUpdate: NoAction, map: "fk-id_ciudad(HB)-id_ciudad(Ciudad)")
  TipoOperacion     TipoOperacion @relation(fields: [id_tipo_operacion], references: [id_tipo_operacion], onDelete: NoAction, onUpdate: NoAction, map: "fk-id_tipo_operacion(HB)-id_tipo_operacion(TipoOperacion)")
  Usuario           Usuario       @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk-id_usuario(HB)-id_usuario(Usuario)")

  @@id([id_usuario, id_ciudad, id_tipo_operacion, fecha_busqueda], map: "HistorialBusqueda_pk")
  @@schema("public")
}

model HistorialVistos {
  id_publicacion Int
  fecha          DateTime?   @db.Timestamptz(6)
  id_usuario     String      @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  Publicacion    Publicacion @relation(fields: [id_publicacion], references: [id_publicacion], onDelete: NoAction, onUpdate: NoAction, map: "fk_historial_publicacion")
  Usuario        Usuario     @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_historial_usuario")

  @@id([id_usuario, id_publicacion], map: "Historial_pk")
  @@schema("public")
}

model Imagen {
  id_imagen      Int          @id(map: "Imagen_pk") @default(autoincrement())
  id_publicacion Int?
  url_imagen     String?
  Publicacion    Publicacion? @relation(fields: [id_publicacion], references: [id_publicacion], onDelete: NoAction, onUpdate: NoAction, map: "fk_imagen_publicacion")

  @@schema("public")
}

model Moneda {
  id_moneda   Int           @id(map: "Moneda_pk") @default(autoincrement())
  nombre      String?       @db.VarChar(128)
  simbolo     String?       @db.Char(1)
  tasa_cambio Decimal?      @db.Decimal(10, 2)
  Publicacion Publicacion[]

  @@schema("public")
}

model Notificacion {
  id_notificacion       String                 @id(map: "Notificacion_pk") @db.Uuid
  titulo                String?                @db.VarChar(256)
  mensaje               String?
  id_categoria          Int?
  leido                 Boolean?
  creado_en             DateTime?              @db.Timestamptz(6)
  id_publicacion        Int                    @default(autoincrement())
  id_usuario            String?                @db.Uuid
  Publicacion           Publicacion            @relation(fields: [id_publicacion], references: [id_publicacion], onDelete: NoAction, onUpdate: NoAction, map: "fk-id_publicacion(Notificacion)-id_publicacion(Publicacion)")
  CategoriaNotificacion CategoriaNotificacion? @relation(fields: [id_categoria], references: [id_categoria], onDelete: NoAction, onUpdate: NoAction, map: "fk_id_categoria(Notificacion)-id_categoria(CatPubli)")
  Usuario               Usuario?               @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_notificacion_usuario")

  @@schema("public")
}

model Pais {
  id_pais     Int         @id(map: "Pais_pk") @default(autoincrement()) @db.SmallInt
  nombre_pais String?     @db.VarChar(128)
  codigo_iso  String?     @db.Char(2)
  Ubicacion   Ubicacion[]

  @@schema("public")
}

model PlanPublicacion {
  id_plan            Int           @id(map: "PlanPublicacion_pk") @default(autoincrement()) @db.SmallInt
  nombre_plan        String?       @db.VarChar(128)
  precio_plan        Decimal?      @db.Decimal(25, 2)
  cant_publicaciones Int?
  DetallePago        DetallePago[]

  @@schema("public")
}

model Publicacion {
  id_publicacion            Int                         @id(map: "Publicacion_pk") @default(autoincrement())
  titulo                    String?                     @db.VarChar(256)
  descripcion               String?
  precio                    Decimal?                    @db.Decimal(25, 2)
  superficie                Decimal?                    @db.Decimal(10, 2)
  habitaciones              Int?                        @db.SmallInt
  banos                     Int?                        @db.SmallInt
  garajes                   Int?                        @db.SmallInt
  plantas                   Int?                        @db.SmallInt
  id_estado_construccion    Int?                        @db.SmallInt
  id_tipo_inmueble          Int?                        @db.SmallInt
  id_tipo_operacion         Int?                        @db.SmallInt
  id_ubicacion              Int?
  id_moneda                 Int?
  id_etiqueta               Int?                        @db.SmallInt
  id_estado                 Int?                        @db.SmallInt
  id_zona                   Int?                        @db.SmallInt
  id_usuario                String?                     @db.Uuid
  Favorito                  Favorito[]
  HistorialVistos           HistorialVistos[]
  Imagen                    Imagen[]
  Notificacion              Notificacion[]
  EstadoPublicacion         EstadoPublicacion?          @relation(fields: [id_estado], references: [id_estado], onDelete: NoAction, onUpdate: NoAction, map: "fk-id_estado(Publicacion)-id_estado(EP)")
  EstadoConstruccion        EstadoConstruccion?         @relation(fields: [id_estado_construccion], references: [id_estado_construccion], onDelete: NoAction, onUpdate: NoAction, map: "fk-id_estado_construccion(P)-id_est_constr(EC)")
  Zona                      Zona?                       @relation(fields: [id_zona], references: [id_zona], onDelete: NoAction, onUpdate: NoAction, map: "fk_id_zona(Publicacion)-id_zona(Zona)")
  Etiquetas                 Etiquetas?                  @relation(fields: [id_etiqueta], references: [id_etiqueta], onDelete: NoAction, onUpdate: NoAction, map: "fk_publicacion_etiqueta")
  Moneda                    Moneda?                     @relation(fields: [id_moneda], references: [id_moneda], onDelete: NoAction, onUpdate: NoAction, map: "fk_publicacion_moneda")
  TipoInmueble              TipoInmueble?               @relation(fields: [id_tipo_inmueble], references: [id_tipo_inmueble], onDelete: NoAction, onUpdate: NoAction, map: "fk_publicacion_tipoinmueble")
  TipoOperacion             TipoOperacion?              @relation(fields: [id_tipo_operacion], references: [id_tipo_operacion], onDelete: NoAction, onUpdate: NoAction, map: "fk_publicacion_tipooperacion")
  Ubicacion                 Ubicacion?                  @relation(fields: [id_ubicacion], references: [id_ubicacion], onDelete: NoAction, onUpdate: NoAction, map: "fk_publicacion_ubicacion")
  Usuario                   Usuario?                    @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_publicacion_usuario")
  PublicacionCaracteristica PublicacionCaracteristica[]
  Video                     Video[]

  @@schema("public")
}

model PublicacionCaracteristica {
  id_publicacion    Int
  id_caracteristica Int
  Caracteristica    Caracteristica @relation(fields: [id_caracteristica], references: [id_caracteristica], onDelete: NoAction, onUpdate: NoAction, map: "fk_publicacioncaracteristica_caracteristica")
  Publicacion       Publicacion    @relation(fields: [id_publicacion], references: [id_publicacion], onDelete: NoAction, onUpdate: NoAction, map: "fk_publicacioncaracteristica_publicacion")

  @@id([id_publicacion, id_caracteristica], map: "PublicacionCaracteristica_pk")
  @@schema("public")
}

model QrUrl {
  id_metodo Int     @id(map: "MetodoPago_pk") @default(autoincrement()) @db.SmallInt
  qr_URL    String?

  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Rol {
  id_rol     Int       @id(map: "Rol_pk") @default(autoincrement())
  nombre_rol String?   @db.VarChar(30)
  Usuario    Usuario[]

  @@schema("public")
}

model Telefono {
  nro_telefono    String            @db.VarChar(12)
  codigo_pais     Int               @db.SmallInt
  UsuarioTelefono UsuarioTelefono[]

  @@id([nro_telefono, codigo_pais], map: "Telefono_pk")
  @@schema("public")
}

model TipoInmueble {
  id_tipo_inmueble Int           @id(map: "TipoInmueble_pk") @default(autoincrement()) @db.SmallInt
  nombre_inmueble  String?       @db.VarChar(128)
  Publicacion      Publicacion[]

  @@schema("public")
}

model TipoOperacion {
  id_tipo_operacion Int                 @id(map: "TipoOperacion_pk") @default(autoincrement()) @db.SmallInt
  nombre_operacion  String?             @db.VarChar(128)
  HistorialBusqueda HistorialBusqueda[]
  Publicacion       Publicacion[]

  @@schema("public")
}

model Ubicacion {
  id_ubicacion Int           @id(map: "Ubicacion_pk") @default(autoincrement())
  id_pais      Int?          @db.SmallInt
  id_ciudad    Int?          @db.SmallInt
  direccion    String?       @db.VarChar(128)
  zona         String?       @db.VarChar(128)
  numero       Int?          @db.SmallInt
  latitud      Decimal?      @db.Decimal(9, 6)
  longitud     Decimal?      @db.Decimal(9, 6)
  Publicacion  Publicacion[]
  Ciudad       Ciudad?       @relation(fields: [id_ciudad], references: [id_ciudad], onDelete: NoAction, onUpdate: NoAction, map: "fk_ubicacion_ciudad")
  Pais         Pais?         @relation(fields: [id_pais], references: [id_pais], onDelete: NoAction, onUpdate: NoAction, map: "fk_ubicacion_pais")

  @@schema("public")
}

model Usuario {
  email                        String?             @db.VarChar(320)
  nombres                      String?             @db.VarChar(100)
  apellidos                    String?             @db.VarChar(100)
  ci                           String?             @db.VarChar(20)
  rol                          Int?
  estado                       Int?                @db.SmallInt
  direccion                    String?             @db.VarChar(200)
  google_id                    String?             @db.VarChar(404)
  cant_publicaciones_restantes Int?                @default(2)
  url_foto_perfil              String?
  username                     String?             @db.VarChar(128)
  id_usuario                   String              @id(map: "Usuario_pk") @db.Uuid
  DetallePago                  DetallePago[]
  Favorito                     Favorito[]
  HistorialBusqueda            HistorialBusqueda[]
  HistorialVistos              HistorialVistos[]
  Notificacion                 Notificacion[]
  Publicacion                  Publicacion[]
  Rol                          Rol?                @relation(fields: [rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
  users                        users               @relation(fields: [id_usuario], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_usuario_auth_users")
  UsuarioTelefono              UsuarioTelefono[]

  @@schema("public")
}

model UsuarioTelefono {
  nro_telefono String   @db.VarChar(12)
  codigo_pais  Int      @db.SmallInt
  id_usuario   String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  Telefono     Telefono @relation(fields: [nro_telefono, codigo_pais], references: [nro_telefono, codigo_pais], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuariotelefono_telefono")
  Usuario      Usuario  @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuariotelefono_usuario")

  @@id([id_usuario, nro_telefono, codigo_pais], map: "UsuarioTelefono_pk")
  @@schema("public")
}

model Video {
  id_video       Int          @id(map: "Video_pk") @default(autoincrement()) @db.SmallInt
  id_publicacion Int?
  url_video      String?
  Publicacion    Publicacion? @relation(fields: [id_publicacion], references: [id_publicacion], onDelete: NoAction, onUpdate: NoAction, map: "fk_video_publicacion")

  @@schema("public")
}

model Zona {
  id_zona     Int           @id(map: "Zona_pk") @default(autoincrement()) @db.SmallInt
  nombre_zona String?       @db.VarChar(128)
  id_ciudad   Int?          @db.SmallInt
  coordenadas String?
  Publicacion Publicacion[]
  Ciudad      Ciudad?       @relation(fields: [id_ciudad], references: [id_ciudad], onDelete: NoAction, onUpdate: NoAction, map: "fk-id_ciudad(Zona)-id_ciudad(Ciudad)")

  @@schema("public")
}

enum aal_level {
  aal1
  aal2
  aal3

  @@schema("auth")
}

enum code_challenge_method {
  s256
  plain

  @@schema("auth")
}

enum factor_status {
  unverified
  verified

  @@schema("auth")
}

enum factor_type {
  totp
  webauthn
  phone

  @@schema("auth")
}

enum oauth_authorization_status {
  pending
  approved
  denied
  expired

  @@schema("auth")
}

enum oauth_client_type {
  public
  confidential

  @@schema("auth")
}

enum oauth_registration_type {
  dynamic
  manual

  @@schema("auth")
}

enum oauth_response_type {
  code

  @@schema("auth")
}

enum one_time_token_type {
  confirmation_token
  reauthentication_token
  recovery_token
  email_change_token_new
  email_change_token_current
  phone_change_token

  @@schema("auth")
}
